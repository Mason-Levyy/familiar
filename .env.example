# .env.example — copy to .env and fill in values (never commit .env)

# Discord bot token (from Discord Developer Portal → Your App → Bot → Token)
DISCORD_BOT_TOKEN=

# Your Discord numeric user ID (only this user may talk to the bot)
# Find it: Discord Settings → Advanced → Enable Developer Mode, then right-click your name
DISCORD_ALLOWED_USER_ID=

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Path to the SQLite database file
DB_PATH=./db/crm.db

# Channel ID where the morning briefing is posted (right-click channel → Copy ID)
DISCORD_BRIEFING_CHANNEL_ID=

# 24-hour time for morning briefing (default: 08:00)
BRIEFING_HOUR=8
BRIEFING_MINUTE=0

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-20250514
